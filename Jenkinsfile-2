 // pipeline_python_agent_alpine
pipeline {
  agent {
    label 'docker_agent_alpine' 
  }
  stages {
    stage('Test') {
      steps {
        sh '''
        python3 --version
        python3 -m venv venv
        source venv/bin/activate
        '''
      }
    }
    stage('Test-dependencies') {
      steps {
        sh '''
        python3 --version
        python3 -m venv venv
        source venv/bin/activate
        pip list
        pip install --upgrade pip
        pip install pytest uv 
        pip list
        '''
      }
    }
    stage('Test-work') {
      steps {
        sh '''
        ls
        python3 main.py
        '''
      }
    }
  }
}