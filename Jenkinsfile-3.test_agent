//Pipeline for work with python how agent at docker
pipeline {
    agent { 
        node{
            label 'docker-agent-python-alpine'
        }
    }   
    triggers{
        pollscm 'H/10 * * * *'
    }
    
    stages {
        stage('Build') {
            steps {
                echo "Building.."
                sh '''
                echo "doing build stuff.."
                '''
            }
        }
        stage('Test') {
            steps {
                echo "Testing.."
                sh '''
                echo "doing test stuff.."
                '''
            }
        }
        stage('Deliver') {
            steps {
                echo 'Deliver....'
                sh '''
                echo "doing delivery stuff.."
                '''
            }
        }
        
    }
}